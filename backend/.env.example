# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hyperdex
MONGODB_DB_NAME=hyperdex

# Stellar
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
USDC_CONTRACT_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
EURC_CONTRACT_ADDRESS=CDOIV56NSBNVNZN4XPTOT7JVRK6AW4RUISEPYUZYIIKMVIY7X3OH4S5X
VAULT_CONTRACT_ADDRESS=CAJBOJRTSXS7CLNOSMO23D2MFXKGKTL3XVQH56H5HKPD6V7SHAHT7SSB
POOL_REGISTRY_CONTRACT_ADDRESS=CCJHRG7A4O36MJ7473AKID4FY6YJAUWCMDFOCB5KUWOP5ZPXVKMKRIK7

# Security
API_KEY_SALT_ROUNDS=10
CORS_ORIGINS=http://localhost:3000,https://hyperdex.app
# Shared secret protecting all /api/admin/* endpoints. REQUIRED — the admin API
# is disabled (500) until this is set. Use a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your-secret-admin-key-here

# RFQ Settings
RFQ_TIMEOUT_MS=750
RFQ_MAX_MAKERS=3
PRICE_LEVEL_STALE_MS=5000
WS_PING_INTERVAL_MS=30000
WS_PONG_TIMEOUT_MS=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX_REQUESTS=10

# Confirmation Poller
POLL_INTERVAL_MS=5000
TX_TIMEOUT_MS=300000
POLL_CONCURRENCY=10
QUOTE_VERIFIER_CONTRACT_ADDRESS=<from_contract_deployment>
