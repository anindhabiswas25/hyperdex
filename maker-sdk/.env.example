# ── Network ───────────────────────────────────────────────────────────────
# Set to 'mainnet' for production. Defaults to testnet if unset.
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ── Token addresses (Stellar Asset Contract / SAC addresses) ────────────────
# Testnet defaults shown. For mainnet, replace with the mainnet SAC (C...)
# addresses. NOTE: the EURC mainnet value must be the SAC contract address,
# not the issuer account.
USDC_CONTRACT_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
EURC_CONTRACT_ADDRESS=CCUUDM434BMZMYWYDITHFXHDMIVTGGD6T2I5UKNX5BSLXLW7HVR4MCGZ

# ── Contract addresses (network-specific, set at deploy time) ───────────────
POOL_REGISTRY_CONTRACT_ADDRESS=
QUOTE_VERIFIER_CONTRACT_ADDRESS=
MAKER_POOL_FACTORY_ADDRESS=

# ── Maker credentials (populated by `npm run setup`) ────────────────────────
MAKER_API_KEY=
SIGNER_PRIVATE_KEY=<64-char hex seed from generate-keypair.ts>
MAKER_ADDRESS=G...
POOL_ADDRESS=
MAKER_NAME=My Maker
PORT=3001

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_WS_URL=wss://hyperdex.onrender.com/ws/maker
BACKEND_HTTP_URL=https://hyperdex.onrender.com
