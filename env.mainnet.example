# =============================================================================
# HyperDEX — CANONICAL MAINNET ENVIRONMENT REFERENCE
# =============================================================================
# This is the single source of truth for every env var that must be set to run
# HyperDEX on Stellar MAINNET. It is committed on purpose (NO SECRETS BELOW —
# only var names, placeholders, and public/well-known values).
#
# Motivation (audit #4 PROC-1): three production outages were caused by hand-
# edited Render/Vercel env silently diverging from the repo. Treat this file as
# the intended state and, after every deploy, READ EACH DEPLOYED VALUE BACK AND
# DIFF IT against this file. Do not trust "I set it."
#
# Placeholders you MUST fill:
#   <FILL: ...>   -> a value produced by deploy/rotation (contract addr, secret)
#   Values shown  -> public/well-known and safe to copy verbatim
#
# Sections map to the three deployment surfaces:
#   1) BACKEND      (Render)
#   2) FRONTEND     (Vercel, NEXT_PUBLIC_* are build-time inlined)
#   3) MAKER-SDK    (24/7 maker host / .cred + .env)
# =============================================================================


# -----------------------------------------------------------------------------
# 0) WELL-KNOWN MAINNET CONSTANTS (copy verbatim)
# -----------------------------------------------------------------------------
# Network passphrase (informational — derived in code from STELLAR_NETWORK):
#   Public Global Stellar Network ; September 2015
#
# Circle token ISSUER accounts (G...) — these are NOT the contract addresses:
#   USDC issuer: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
#   EURC issuer: GDHU6WRG4IEQXM5NZ4BMPKOXHW76MZM4Y2IEMFDVXBSDP6SJY4ITNPP2
#
# The app needs the Stellar Asset CONTRACT (SAC, C...) addresses, derived from
# the issuers above:
#   stellar contract id asset --asset USDC:GA5ZSEJY...KZVN --network mainnet
#   stellar contract id asset --asset EURC:GDHU6WRG...NPP2 --network mainnet
# Known mainnet USDC SAC:
#   CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75
# EURC SAC (derived + verified): CDTKPWPLOURQA2SGTKTUQOWRCBZEORB4BWBOMJ3D3ZTQQSGE5F6JBQLV
# On mainnet the code FAILS CLOSED if a token addr is missing or is a G...
# (issuer) instead of C... (contract).


# =============================================================================
# 1) BACKEND  —  Render (always-on service; free tier sleeps → do NOT use it)
# =============================================================================

# ── Server ──
PORT=4000
NODE_ENV=production

# ── MongoDB (use a SEPARATE production database from testnet) ──
MONGODB_URI=<FILL: mainnet Atlas SRI, rotated credential — never the testnet one>
MONGODB_DB_NAME=hyperdex_mainnet

# ── Stellar ──
STELLAR_NETWORK=mainnet
# Use a RELIABLE/PAID Soroban RPC — the public endpoint rate-limits the 5s
# poller and RFQ balance sims and will starve liquidity.
STELLAR_RPC_URL=<FILL: paid mainnet Soroban RPC (Validation Cloud/Blockdaemon/QuickNode)>
HORIZON_URL=https://horizon.stellar.org

# Token SAC (C...) addresses — see section 0.
USDC_CONTRACT_ADDRESS=CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75
EURC_CONTRACT_ADDRESS=CDTKPWPLOURQA2SGTKTUQOWRCBZEORB4BWBOMJ3D3ZTQQSGE5F6JBQLV

# Contract addresses — from `scripts/deploy-v2.sh` on mainnet (record all 4).
POOL_REGISTRY_CONTRACT_ADDRESS=CDONQCEJFQHOUIFWB4X4K2MVSFXH6HLEYPWRBPTAUR4WZNP2FD4YSQWW
QUOTE_VERIFIER_CONTRACT_ADDRESS=CDMOUCUKCZRMSYQE5TQ7QVGVUFJYFSP7XLLBHL3ZE2EQLZGZUFC4PHXK
MAKER_POOL_FACTORY_ADDRESS=CBDD5WBPCX6GSF4XIP6CAKAM3TCU6R73CW7QNYUTXXT3OAGEPFFACOI4
FEE_DISTRIBUTOR_CONTRACT_ADDRESS=CAAWWYIUWKV2Z4OGAVBXNVRGRCN3QY3FF4M2BLV72V2MBNEVFLMSAU2R
# Legacy single-vault address (only if your build still references it).
# VAULT_CONTRACT_ADDRESS=<FILL or remove>

# ── Security ──
API_KEY_SALT_ROUNDS=10
# Comma-separated allowed browser origins. MUST include the exact prod Vercel
# origin(s) or every browser call is CORS-blocked (audit #4 PROC-1 #1).
CORS_ORIGINS=https://<FILL: prod-frontend-domain>
# REQUIRED — admin API returns 500 until set. Fresh strong random for mainnet:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=<FILL: fresh 32-byte random, NOT reused from testnet>

# ── RFQ / auction ──
RFQ_TIMEOUT_MS=750
RFQ_MAX_MAKERS=3
PRICE_LEVEL_STALE_MS=5000
WS_PING_INTERVAL_MS=30000
WS_PONG_TIMEOUT_MS=10000

# ── Rate limiting ──
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX_REQUESTS=10

# ── Confirmation poller ──
POLL_INTERVAL_MS=5000
TX_TIMEOUT_MS=300000
POLL_CONCURRENCY=10


# =============================================================================
# 2) FRONTEND  —  Vercel
# NEXT_PUBLIC_* are INLINED AT BUILD TIME. After changing any of these you MUST
# REDEPLOY and then VERIFY THE LIVE BUNDLE serves the new values (audit #4
# PROC-1 #2: 49-day-stale factory addr bricked on-chain deploy_pool).
# =============================================================================

NEXT_PUBLIC_STELLAR_NETWORK=mainnet
NEXT_PUBLIC_STELLAR_RPC_URL=<FILL: paid mainnet Soroban RPC (same as backend)>
NEXT_PUBLIC_HORIZON_URL=https://horizon.stellar.org
NEXT_PUBLIC_BACKEND_URL=https://<FILL: prod backend origin, e.g. hyperdex.onrender.com>

# Token SAC (C...) addresses — must match the backend exactly.
NEXT_PUBLIC_USDC_CONTRACT=CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75
NEXT_PUBLIC_EURC_CONTRACT=CDTKPWPLOURQA2SGTKTUQOWRCBZEORB4BWBOMJ3D3ZTQQSGE5F6JBQLV

# Contract addresses — must match the backend deploy exactly.
NEXT_PUBLIC_POOL_REGISTRY_CONTRACT=CDONQCEJFQHOUIFWB4X4K2MVSFXH6HLEYPWRBPTAUR4WZNP2FD4YSQWW
NEXT_PUBLIC_QUOTE_VERIFIER_CONTRACT=CDMOUCUKCZRMSYQE5TQ7QVGVUFJYFSP7XLLBHL3ZE2EQLZGZUFC4PHXK
NEXT_PUBLIC_MAKER_POOL_FACTORY_ADDRESS=CBDD5WBPCX6GSF4XIP6CAKAM3TCU6R73CW7QNYUTXXT3OAGEPFFACOI4
NEXT_PUBLIC_FEE_DISTRIBUTOR_CONTRACT=CAAWWYIUWKV2Z4OGAVBXNVRGRCN3QY3FF4M2BLV72V2MBNEVFLMSAU2R

# Admin wallet PUBLIC address (G...) — public, used for UI gating only. The
# admin API KEY is entered in the browser at runtime (localStorage), never here.
NEXT_PUBLIC_ADMIN_ADDRESS=GAL6ZVVRE2RPFS2X23I65QANHHIBGHKTGGVIT5AJURRKTIMEVUMJJUZZ


# =============================================================================
# 3) MAKER-SDK  —  24/7 maker host (.env + credentials/<name>.cred)
# On mainnet the SDK FAILS CLOSED if a token addr is missing or is a G... addr.
# =============================================================================

STELLAR_NETWORK=mainnet
STELLAR_RPC_URL=<FILL: paid mainnet Soroban RPC>

# Token SAC (C...) addresses — must match backend/frontend.
USDC_CONTRACT_ADDRESS=CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75
EURC_CONTRACT_ADDRESS=CDTKPWPLOURQA2SGTKTUQOWRCBZEORB4BWBOMJ3D3ZTQQSGE5F6JBQLV

# Contract addresses (network-specific, set at deploy time).
POOL_REGISTRY_CONTRACT_ADDRESS=CDONQCEJFQHOUIFWB4X4K2MVSFXH6HLEYPWRBPTAUR4WZNP2FD4YSQWW
QUOTE_VERIFIER_CONTRACT_ADDRESS=CDMOUCUKCZRMSYQE5TQ7QVGVUFJYFSP7XLLBHL3ZE2EQLZGZUFC4PHXK
MAKER_POOL_FACTORY_ADDRESS=CBDD5WBPCX6GSF4XIP6CAKAM3TCU6R73CW7QNYUTXXT3OAGEPFFACOI4

# Backend endpoints (prod).
BACKEND_WS_URL=wss://<FILL: prod backend origin>/ws/maker
BACKEND_HTTP_URL=https://<FILL: prod backend origin>

# ── Per-maker credentials — GENERATE FRESH ON MAINNET (never reuse testnet) ──
# Populated by `npm run setup`; keep in gitignored credentials/<name>.cred.
MAKER_API_KEY=<FILL: issued by backend on approval>
SIGNER_PRIVATE_KEY=<FILL: fresh 64-char hex seed (generate-keypair.ts)>
MAKER_ADDRESS=<FILL: maker Stellar account (G...)>
POOL_ADDRESS=<FILL: deployed pool contract (C...)>
MAKER_NAME=<FILL: maker display name>
PORT=3001


# =============================================================================
# POST-DEPLOY VERIFICATION (do not skip)
# =============================================================================
# [ ] Backend:  curl https://<backend>/health  -> status:ok, dbStatus:connected
# [ ] Frontend: view-source the live bundle; confirm the mainnet factory addr is
#               present and NO testnet/old addr remains.
# [ ] CORS:     a real browser call from the prod domain succeeds (not blocked).
# [ ] Tokens:   USDC/EURC in all three surfaces are identical C... SAC addrs.
# [ ] Secrets:  ADMIN_API_KEY, MONGODB_URI, maker signer keys are all NEW — no
#               testnet value from memory/ or *.cred is reused.
# [ ] Live:     one real quote + one tiny real swap settle on mainnet before
#               opening liquidity.
# =============================================================================
